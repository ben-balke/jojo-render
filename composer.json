{
  "name": "ben-balke/jojo-render",
  "description": "Jojo Render - a lightweight template DSL with provider-based resolution",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Ben Balke",
      "email": "ben.balke@duckdigit.com"
    }
  ],
  "keywords": [
    "template",
    "dsl",
    "render",
    "crm",
    "suitecrm",
    "email"
  ],
  "autoload": {
    "psr-4": {
